{% extends 'layout.html.twig' %}
{% block title %} Home {% endblock title %}
{% block content %}
    {{ include('partials/hero.html.twig') }}

    <!-- Categories Section -->
    <div class="container my-5" id="categories">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Shop by Category</h2>
            <p class="text-muted">Explore our wide range of products organized by category</p>
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for categorie in categories %}
            <!-- Category 1: Electronics -->
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <span class="badge bg-primary mb-2">12 Products</span>
                        <h4 class="card-title">{{ categorie.name }}</h4>
                        <p class="card-text text-muted">{{ categorie.description }}</p>
                        <a href="{{ path('app_products_by_category', {id: categorie.id}) }}" class="btn btn-outline-primary">Browse {{ categorie.name }}</a>
                    </div>
                </div>
            </div>

            {% endfor %}
        </div>
    </div>

    {{ include('partials/features-section.html.twig') }}
{% endblock content %}
