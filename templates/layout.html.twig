{% extends 'base.html.twig' %}
{% block body %}
    <div class="d-flex flex-column min-vh-100">
        <!-- Header -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand" href="home.html">Our Store</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link active" href={{ path('app_category') }}>Categories</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href={{ path('app_product') }}>Products</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href={{ path('cart_show') }}>Cart</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="profile.html">Profile</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <main class="flex-grow-1">
            {% block content %}{% endblock content %}
        </main>

        <!-- Footer -->
        <footer class="bg-dark text-white mt-auto py-4">
            <div class="container">
                <div class="row">
                    <div class="col-md-6">
                        <h5>Our Store</h5>
                        <p>Quality products at affordable prices</p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <p>&copy; 2026 Our Store. All rights reserved.</p>
                    </div>
                </div>
            </div>
        </footer>
    </div>
{% endblock body %}
