{% extends 'layout.html.twig' %}

{% block title %}{{ category.name }}{% endblock %}

{% block content %}

    <!-- Breadcrumb -->
    <div class="container mt-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('app_category') }}" class="text-decoration-none">Home</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_category') }}" class="text-decoration-none">Categories</a></li>
                <li class="breadcrumb-item active" aria-current="page">{{ category.name }}</li>
            </ol>
        </nav>
    </div>

    <!-- Jumbotron -->
    <div class="container my-4">
        <div class="p-5 mb-4 bg-primary bg-gradient text-white rounded-3">
            <div class="container-fluid py-3">
                <h1 class="display-4 fw-bold">{{ category.name }}</h1>
                <p class="col-md-8 fs-5">{{ category.description }}</p>
                <span class="badge bg-light text-dark fs-6">{{ products|length }} Products Available</span>
            </div>
        </div>
    </div>

    <!-- Products -->
    <div class="container mb-5">
        <div class="row mb-4">
            <div class="col">
                <div class="d-flex justify-content-between align-items-center">
                    <h3>Browse {{ category.name }}</h3>
                </div>
            </div>
        </div>

        <div class="row row-cols-1 row-cols-md-3 g-4">
            {% for product in products %}
                <div class="col">
                    <div class="card h-100">
                        <img src="/img/item.png" class="card-img-top" alt="{{ product.name }}">
                        <div class="card-body">
                            <span class="badge bg-primary mb-2">{{ category.name }}</span>
                            <h5 class="card-title">{{ product.name }}</h5>
                            <p class="card-text fw-bold text-success">${{ product.sellPrice }}</p>
                            <a href="{{ path('app_product_show', {id: product.id}) }}" class="btn btn-outline-primary">View Details</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col">
                    <p class="text-muted">No products found in this category.</p>
                </div>
            {% endfor %}
        </div>
    </div>

{% endblock %}
