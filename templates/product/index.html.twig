{% extends 'layout.html.twig' %}
{% block title %} product name {% endblock title %}
{% block content %}

    <!-- Products Section -->
    <div class="container my-5">
        <h1 class="mb-4">Our Products</h1>

        <div class="row row-cols-1 row-cols-md-3 g-4">
            <!-- Product 1 -->
            <div class="col">
                <div class="card h-100">
                    <img src="item.png" class="card-img-top" alt="Product 1">
                    <div class="card-body">
                        <span class="badge bg-primary mb-2">Electronics</span>
                        <h5 class="card-title">Wireless Headphones</h5>
                        <p class="card-text fw-bold text-success">$79.99</p>
                        <a href="details.html?id=1" class="btn btn-outline-primary">View Details</a>
                    </div>
                </div>
            </div>

            <!-- Product 2 -->
            <div class="col">
                <div class="card h-100">
                    <img src="item.png" class="card-img-top" alt="Product 2">
                    <div class="card-body">
                        <span class="badge bg-warning mb-2">Fashion</span>
                        <h5 class="card-title">Classic Leather Jacket</h5>
                        <p class="card-text fw-bold text-success">$149.99</p>
                        <a href="details.html?id=2" class="btn btn-outline-primary">View Details</a>
                    </div>
                </div>
            </div>

            <!-- Product 3 -->
            <div class="col">
                <div class="card h-100">
                    <img src="item.png" class="card-img-top" alt="Product 3">
                    <div class="card-body">
                        <span class="badge bg-success mb-2">Home & Garden</span>
                        <h5 class="card-title">Smart Plant Sensor</h5>
                        <p class="card-text fw-bold text-success">$34.99</p>
                        <a href="details.html?id=3" class="btn btn-outline-primary">View Details</a>
                    </div>
                </div>
            </div>

            <!-- Product 4 -->
            <div class="col">
                <div class="card h-100">
                    <img src="item.png" class="card-img-top" alt="Product 4">
                    <div class="card-body">
                        <span class="badge bg-info mb-2">Sports</span>
                        <h5 class="card-title">Yoga Mat Premium</h5>
                        <p class="card-text fw-bold text-success">$29.99</p>
                        <a href="details.html?id=4" class="btn btn-outline-primary">View Details</a>
                    </div>
                </div>
            </div>

            <!-- Product 5 -->
            <div class="col">
                <div class="card h-100">
                    <img src="item.png" class="card-img-top" alt="Product 5">
